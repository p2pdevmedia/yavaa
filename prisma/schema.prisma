generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
}

enum OnboardingRole {
  JEFE       @map("jefe")
  TRABAJADOR @map("trabajador")

  @@map("onboarding_role")
}

enum IdentityVerificationStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED

  @@map("identity_verification_status")
}

enum JobPostStatus {
  DRAFT
  PUBLISHED
  CLOSED
  CANCELLED
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  email          String     @unique
  supabaseAuthId String?    @unique @map("supabase_auth_id")
  displayName    String?    @map("display_name")
  status         UserStatus @default(ACTIVE)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  profile Profile?
  roles   UserRole[]
  jobPosts JobPost[]

  @@map("users")
}

model Profile {
  id                          String                     @id @default(uuid()) @db.Uuid
  userId                      String                     @unique @map("user_id") @db.Uuid
  firstName                   String?                    @map("first_name")
  lastName                    String?                    @map("last_name")
  avatarUrl                   String?                    @map("avatar_url")
  phone                       String?
  bio                         String?
  onboardingRole              OnboardingRole?            @map("onboarding_role")
  workerOnboardingCompletedAt DateTime?                  @map("worker_onboarding_completed_at")
  jefeOnboardingCompletedAt   DateTime?                  @map("jefe_onboarding_completed_at")
  identityVerificationStatus  IdentityVerificationStatus @default(NOT_STARTED) @map("identity_verification_status")
  dniNumber                   String?                    @map("dni_number")
  workerCategories            String[]                   @default([]) @map("worker_categories")
  workerHourlyRateCents       Int?                       @map("worker_hourly_rate_cents")
  addressText                 String?                    @map("address_text")
  locationLatitude            Decimal?                   @map("location_latitude") @db.Decimal(9, 6)
  locationLongitude           Decimal?                   @map("location_longitude") @db.Decimal(9, 6)
  createdAt                   DateTime                   @default(now()) @map("created_at")
  updatedAt                   DateTime                   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model JobPost {
  id          String        @id @default(uuid()) @db.Uuid
  clientId    String        @map("client_id") @db.Uuid
  title       String
  category    String
  description String
  addressText String        @map("address_text")
  desiredTime DateTime?     @map("desired_time")
  photoPathnames String[]    @default([]) @map("photo_pathnames")
  status      JobPostStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  client User @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([category, status])
  @@map("job_posts")
}
