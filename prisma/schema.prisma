generator client {
  provider = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
  PENDING_REVIEW
}

enum ContractorApprovalStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING_ACCEPTANCE
  ACCEPTED
  REJECTED_BY_CONTRACTOR
  CANCELLED_BY_CLIENT
  RESCHEDULE_REQUESTED
}

enum EmergencyRequestStatus {
  OPEN
  DISPATCHING
  ACCEPTED
  CANCELLED_BY_CLIENT
  REASSIGNMENT_NEEDED
  EXPIRED
}

enum EmergencyRequestCandidateStatus {
  NOTIFIED
  ACCEPTED
  IGNORED
  EXPIRED
  REVOKED
}

enum AddressType {
  HOME
  WORK
  OTHER
}

enum BookingMessageKind {
  USER
  SYSTEM
}

enum BookingFilePurpose {
  CHAT_ATTACHMENT
  PROBLEM_PHOTO
  PAYMENT_PROOF
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_MESSAGE
  BOOKING_STATUS_CHANGED
  BOOKING_FILE_UPLOADED
}

enum CommissionDebtStatus {
  OPEN
  PAID
  CANCELLED
}

enum CommissionDebtSourceType {
  ADMIN_ADJUSTMENT
  BOOKING_COMMISSION
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  email          String     @unique
  supabaseAuthId  String?    @unique @map("supabase_auth_id")
  displayName    String?    @map("display_name")
  status         UserStatus @default(ACTIVE)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  profile                    Profile?
  contractorProfile          ContractorProfile?
  addresses                  Address[]
  roles                      UserRole[]
  bookingsAsClient           Booking[] @relation("BookingClient")
  bookingMessagesSent        BookingMessage[] @relation("BookingMessageSender")
  bookingFilesUploaded       BookingFile[] @relation("BookingFileUploader")
  notificationsReceived      Notification[] @relation("NotificationRecipient")
  notificationsSent          Notification[] @relation("NotificationActor")
  emergencyRequestsAsClient   EmergencyRequest[] @relation("EmergencyClient")
  auditLogs                  AuditLog[] @relation("AuditActor")
  reviewedContractorProfiles  ContractorProfile[] @relation("ContractorReviewActor")
  commissionDebts             CommissionDebt[] @relation("DebtUser")
  commissionDebtsCreated      CommissionDebt[] @relation("DebtCreator")
  debtLimit                   UserDebtLimit?   @relation("DebtLimitUser")
  debtLimitsSet               UserDebtLimit[]  @relation("DebtLimitSetter")

  @@map("users")
}

model Profile {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  avatarUrl String?  @map("avatar_url")
  phone     String?
  bio       String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  slug        String     @unique
  name        String
  description String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  action       String
  entityType   String   @map("entity_type")
  entityId     String?  @map("entity_id")
  metadata     Json?    @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at")

  actorUser User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actorUserId])
  @@map("audit_logs")
}

model CommissionDebt {
  id              String                   @id @default(uuid()) @db.Uuid
  userId          String                   @map("user_id") @db.Uuid
  sourceType      CommissionDebtSourceType @default(ADMIN_ADJUSTMENT) @map("source_type")
  sourceId        String?                  @map("source_id")
  amountCents     Int                      @map("amount_cents")
  currency        String                   @default("ARS")
  status          CommissionDebtStatus     @default(OPEN)
  reason          String
  createdByUserId String?                  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  user          User  @relation("DebtUser", fields: [userId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("DebtCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([createdByUserId])
  @@index([sourceType, sourceId])
  @@index([createdAt])
  @@map("commission_debts")
}

model UserDebtLimit {
  userId      String   @id @map("user_id") @db.Uuid
  limitCents  Int      @map("limit_cents")
  currency    String   @default("ARS")
  setByUserId String   @map("set_by_user_id") @db.Uuid
  reason      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User @relation("DebtLimitUser", fields: [userId], references: [id], onDelete: Cascade)
  setByUser User @relation("DebtLimitSetter", fields: [setByUserId], references: [id], onDelete: Restrict)

  @@index([setByUserId])
  @@map("user_debt_limits")
}

model Market {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  country     String
  province    String
  city        String
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  addresses  Address[]
  workZones  WorkZone[]

  @@map("markets")
}

model Category {
  id          String         @id @default(uuid()) @db.Uuid
  slug        String         @unique
  name        String
  group       String?        @map("category_group")
  status      CategoryStatus @default(ACTIVE)
  isInitial   Boolean        @default(false) @map("is_initial")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  contractorCategories ContractorCategory[]
  bookings             Booking[]
  emergencyRequests    EmergencyRequest[]

  @@index([status])
  @@index([group])
  @@map("categories")
}

model Address {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  marketId   String?     @map("market_id") @db.Uuid
  label      String
  line1      String      @map("line_1")
  line2      String?     @map("line_2")
  city       String
  province   String
  postalCode String?     @map("postal_code")
  notes      String?
  type       AddressType @default(HOME) @map("address_type")
  isDefault  Boolean     @default(false) @map("is_default")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market? @relation(fields: [marketId], references: [id], onDelete: SetNull)

  contractorProfile ContractorProfile?
  bookings          Booking[]
  emergencyRequests EmergencyRequest[]

  @@index([userId])
  @@index([marketId])
  @@map("addresses")
}

model WorkZone {
  id          String   @id @default(uuid()) @db.Uuid
  marketId    String   @map("market_id") @db.Uuid
  slug        String
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  contractorLinks ContractorWorkZone[]

  @@unique([marketId, slug])
  @@index([marketId])
  @@map("work_zones")
}

model ContractorProfile {
  id               String                   @id @default(uuid()) @db.Uuid
  userId           String                   @unique @map("user_id") @db.Uuid
  addressId        String?                  @unique @map("address_id") @db.Uuid
  approvalStatus   ContractorApprovalStatus @default(DRAFT) @map("approval_status")
  acceptsEmergencies Boolean                @default(false) @map("accepts_emergencies")
  dniNumber        String?                  @unique @map("dni_number")
  dniFrontUrl      String?                  @map("dni_front_url")
  dniBackUrl       String?                  @map("dni_back_url")
  profilePhotoUrl  String?                  @map("profile_photo_url")
  reviewNotes      String?                  @map("review_notes")
  submittedAt      DateTime?                @map("submitted_at")
  reviewedAt       DateTime?                @map("reviewed_at")
  reviewedByUserId  String?                  @map("reviewed_by_user_id") @db.Uuid
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  address    Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)
  reviewedBy User?   @relation("ContractorReviewActor", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  categories ContractorCategory[]
  workZones  ContractorWorkZone[]
  bookings   Booking[]
  emergencyCandidates EmergencyRequestCandidate[]
  emergencyAssignments EmergencyRequest[] @relation("EmergencyAssignedContractor")

  @@index([approvalStatus])
  @@index([reviewedByUserId])
  @@map("contractor_profiles")
}

model ContractorCategory {
  contractorProfileId String   @map("contractor_profile_id") @db.Uuid
  categoryId          String   @map("category_id") @db.Uuid
  isPrimary           Boolean  @default(false) @map("is_primary")
  createdAt           DateTime @default(now()) @map("created_at")

  contractorProfile ContractorProfile @relation(fields: [contractorProfileId], references: [id], onDelete: Cascade)
  category          Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@id([contractorProfileId, categoryId])
  @@index([categoryId])
  @@map("contractor_categories")
}

model ContractorWorkZone {
  contractorProfileId String   @map("contractor_profile_id") @db.Uuid
  workZoneId          String   @map("work_zone_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")

  contractorProfile ContractorProfile @relation(fields: [contractorProfileId], references: [id], onDelete: Cascade)
  workZone          WorkZone          @relation(fields: [workZoneId], references: [id], onDelete: Restrict)

  @@id([contractorProfileId, workZoneId])
  @@index([workZoneId])
  @@map("contractor_work_zones")
}

model Booking {
  id                  String         @id @default(uuid()) @db.Uuid
  clientUserId        String         @map("client_user_id") @db.Uuid
  contractorProfileId String         @map("contractor_profile_id") @db.Uuid
  categoryId          String         @map("category_id") @db.Uuid
  addressId           String         @map("address_id") @db.Uuid
  scheduledFor        DateTime       @map("scheduled_for")
  description         String
  status              BookingStatus  @default(PENDING_ACCEPTANCE)
  contractorNote      String?        @map("contractor_note")
  decisionReason      String?        @map("decision_reason")
  rescheduleRequestedAt DateTime?     @map("reschedule_requested_at")
  acceptedAt          DateTime?      @map("accepted_at")
  rejectedAt          DateTime?      @map("rejected_at")
  cancelledAt         DateTime?      @map("cancelled_at")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  client             User              @relation("BookingClient", fields: [clientUserId], references: [id], onDelete: Cascade)
  contractorProfile  ContractorProfile @relation(fields: [contractorProfileId], references: [id], onDelete: Restrict)
  category           Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  address            Address           @relation(fields: [addressId], references: [id], onDelete: Restrict)
  messages           BookingMessage[]
  files              BookingFile[]
  notifications      Notification[]

  @@index([clientUserId])
  @@index([contractorProfileId])
  @@index([status])
  @@index([scheduledFor])
  @@map("bookings")
}

model BookingMessage {
  id           String            @id @default(uuid()) @db.Uuid
  bookingId    String            @map("booking_id") @db.Uuid
  senderUserId String?           @map("sender_user_id") @db.Uuid
  kind         BookingMessageKind @default(USER)
  systemEvent  String?           @map("system_event")
  body         String
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  booking    Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  senderUser User?   @relation("BookingMessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  files      BookingFile[]

  @@index([bookingId])
  @@index([senderUserId])
  @@index([kind])
  @@map("booking_messages")
}

model BookingFile {
  id             String           @id @default(uuid()) @db.Uuid
  bookingId      String           @map("booking_id") @db.Uuid
  messageId      String?          @map("message_id") @db.Uuid
  uploadedByUserId String         @map("uploaded_by_user_id") @db.Uuid
  purpose        BookingFilePurpose @default(CHAT_ATTACHMENT)
  fileName       String          @map("file_name")
  mimeType       String          @map("mime_type")
  storageKey     String          @unique @map("storage_key")
  storageUrl     String?         @map("storage_url")
  sizeBytes      Int?            @map("size_bytes")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  booking      Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  message      BookingMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  uploadedByUser User        @relation("BookingFileUploader", fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([messageId])
  @@index([uploadedByUserId])
  @@index([purpose])
  @@map("booking_files")
}

model Notification {
  id             String           @id @default(uuid()) @db.Uuid
  recipientUserId String          @map("recipient_user_id") @db.Uuid
  actorUserId    String?          @map("actor_user_id") @db.Uuid
  bookingId      String?          @map("booking_id") @db.Uuid
  type           NotificationType
  title          String
  body           String
  metadata       Json?            @db.JsonB
  isRead         Boolean          @default(false) @map("is_read")
  readAt         DateTime?        @map("read_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  recipientUser  User             @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  actorUser      User?            @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  booking        Booking?         @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, isRead, createdAt])
  @@index([bookingId])
  @@index([type])
  @@map("notifications")
}

model EmergencyRequest {
  id                       String                @id @default(uuid()) @db.Uuid
  clientUserId             String                @map("client_user_id") @db.Uuid
  categoryId               String                @map("category_id") @db.Uuid
  addressId                String                @map("address_id") @db.Uuid
  assignedContractorProfileId String?            @map("assigned_contractor_profile_id") @db.Uuid
  description              String
  status                   EmergencyRequestStatus @default(DISPATCHING)
  dispatchRound            Int                   @default(1) @map("dispatch_round")
  expiresAt                DateTime              @map("expires_at")
  acceptedAt               DateTime?             @map("accepted_at")
  cancelledAt              DateTime?             @map("cancelled_at")
  createdAt                DateTime              @default(now()) @map("created_at")
  updatedAt                DateTime              @updatedAt @map("updated_at")

  client                  User              @relation("EmergencyClient", fields: [clientUserId], references: [id], onDelete: Cascade)
  category                Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  address                 Address           @relation(fields: [addressId], references: [id], onDelete: Restrict)
  assignedContractorProfile ContractorProfile? @relation("EmergencyAssignedContractor", fields: [assignedContractorProfileId], references: [id], onDelete: SetNull)
  candidates              EmergencyRequestCandidate[]

  @@index([clientUserId])
  @@index([assignedContractorProfileId])
  @@index([status])
  @@index([expiresAt])
  @@map("emergency_requests")
}

model EmergencyRequestCandidate {
  id                  String                      @id @default(uuid()) @db.Uuid
  emergencyRequestId   String                      @map("emergency_request_id") @db.Uuid
  contractorProfileId  String                      @map("contractor_profile_id") @db.Uuid
  dispatchRound        Int                         @map("dispatch_round")
  status               EmergencyRequestCandidateStatus @default(NOTIFIED)
  notifiedAt           DateTime                    @default(now()) @map("notified_at")
  respondedAt          DateTime?                   @map("responded_at")
  responseNote         String?                     @map("response_note")
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime                    @updatedAt @map("updated_at")

  emergencyRequest     EmergencyRequest            @relation(fields: [emergencyRequestId], references: [id], onDelete: Cascade)
  contractorProfile    ContractorProfile           @relation(fields: [contractorProfileId], references: [id], onDelete: Restrict)

  @@index([emergencyRequestId])
  @@index([contractorProfileId])
  @@index([status])
  @@map("emergency_request_candidates")
}
