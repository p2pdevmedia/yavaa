generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
}

enum OnboardingRole {
  JEFE       @map("jefe")
  TRABAJADOR @map("trabajador")

  @@map("onboarding_role")
}

enum IdentityVerificationStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED

  @@map("identity_verification_status")
}

enum JobPostStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  READY_FOR_REVIEW
  CLOSED
  CANCELLED
}

enum JobOfferStatus {
  PENDING
  ACCEPTED
  REJECTED

  @@map("job_offer_status")
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  email          String     @unique
  supabaseAuthId String?    @unique @map("supabase_auth_id")
  displayName    String?    @map("display_name")
  status         UserStatus @default(ACTIVE)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  profile       Profile?
  roles         UserRole[]
  jobPosts      JobPost[]
  jobOffers     JobOffer[]        @relation("worker_job_offers")
  offerMessages JobOfferMessage[]
  jobPayments   JobPayment[]
  addresses     UserAddress[]

  @@map("users")
}

model Profile {
  id                          String                     @id @default(uuid()) @db.Uuid
  userId                      String                     @unique @map("user_id") @db.Uuid
  firstName                   String?                    @map("first_name")
  lastName                    String?                    @map("last_name")
  avatarUrl                   String?                    @map("avatar_url")
  phone                       String?
  bio                         String?
  onboardingRole              OnboardingRole?            @map("onboarding_role")
  workerOnboardingCompletedAt DateTime?                  @map("worker_onboarding_completed_at")
  jefeOnboardingCompletedAt   DateTime?                  @map("jefe_onboarding_completed_at")
  identityVerificationStatus  IdentityVerificationStatus @default(NOT_STARTED) @map("identity_verification_status")
  dniNumber                   String?                    @map("dni_number")
  workerCategories            String[]                   @default([]) @map("worker_categories")
  workerHourlyRateCents       Int?                       @map("worker_hourly_rate_cents")
  addressText                 String?                    @map("address_text")
  locationLatitude            Decimal?                   @map("location_latitude") @db.Decimal(9, 6)
  locationLongitude           Decimal?                   @map("location_longitude") @db.Decimal(9, 6)
  createdAt                   DateTime                   @default(now()) @map("created_at")
  updatedAt                   DateTime                   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model UserAddress {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  name              String
  addressText       String   @map("address_text")
  locationLatitude  Decimal  @map("location_latitude") @db.Decimal(9, 6)
  locationLongitude Decimal  @map("location_longitude") @db.Decimal(9, 6)
  isPrimary         Boolean  @default(false) @map("is_primary")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isPrimary])
  @@map("user_addresses")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model JobPost {
  id              String        @id @default(uuid()) @db.Uuid
  clientId        String        @map("client_id") @db.Uuid
  acceptedOfferId String?       @unique @map("accepted_offer_id") @db.Uuid
  title           String
  category        String
  description     String
  addressText     String        @map("address_text")
  desiredTime     DateTime?     @map("desired_time")
  photoPathnames  String[]      @default([]) @map("photo_pathnames")
  status          JobPostStatus @default(PUBLISHED)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  client        User       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  offers        JobOffer[] @relation("job_post_offers")
  acceptedOffer JobOffer?  @relation("accepted_job_offer", fields: [acceptedOfferId, id], references: [id, jobPostId], onDelete: NoAction)

  @@unique([acceptedOfferId, id])
  @@index([clientId, createdAt])
  @@index([category, status])
  @@index([status, createdAt])
  @@map("job_posts")
}

model JobOffer {
  id          String         @id @default(uuid()) @db.Uuid
  jobPostId   String         @map("job_post_id") @db.Uuid
  workerId    String         @map("worker_id") @db.Uuid
  amountCents Int            @map("amount_cents")
  status      JobOfferStatus @default(PENDING)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  jobPost        JobPost           @relation("job_post_offers", fields: [jobPostId], references: [id], onDelete: Cascade)
  acceptedForJob JobPost?          @relation("accepted_job_offer")
  worker         User              @relation("worker_job_offers", fields: [workerId], references: [id], onDelete: Cascade)
  messages       JobOfferMessage[]
  payments       JobPayment[]

  @@unique([jobPostId, workerId])
  @@unique([id, jobPostId])
  @@index([workerId, status])
  @@index([jobPostId, status])
  @@map("job_offers")
}

model JobOfferMessage {
  id        String   @id @default(uuid()) @db.Uuid
  offerId   String   @map("offer_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  offer  JobOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  author User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([offerId, createdAt])
  @@map("job_offer_messages")
}

model JobPayment {
  id              String   @id @default(uuid()) @db.Uuid
  offerId         String   @map("offer_id") @db.Uuid
  createdById     String   @map("created_by_id") @db.Uuid
  amountCents     Int      @map("amount_cents")
  paidAt          DateTime @map("paid_at")
  description     String
  receiptPathname String?  @map("receipt_pathname")
  createdAt       DateTime @default(now()) @map("created_at")

  offer     JobOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([offerId, paidAt])
  @@map("job_payments")
}
