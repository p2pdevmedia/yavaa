generator client {
  provider = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
  PENDING_REVIEW
}

enum ContractorApprovalStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum AddressType {
  HOME
  WORK
  OTHER
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  email          String     @unique
  supabaseAuthId  String?    @unique @map("supabase_auth_id")
  displayName    String?    @map("display_name")
  status         UserStatus @default(ACTIVE)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  profile                    Profile?
  contractorProfile          ContractorProfile?
  addresses                  Address[]
  roles                      UserRole[]
  auditLogs                  AuditLog[] @relation("AuditActor")
  reviewedContractorProfiles  ContractorProfile[] @relation("ContractorReviewActor")

  @@map("users")
}

model Profile {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  avatarUrl String?  @map("avatar_url")
  phone     String?
  bio       String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  slug        String     @unique
  name        String
  description String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  action       String
  entityType   String   @map("entity_type")
  entityId     String?  @map("entity_id")
  metadata     Json?    @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at")

  actorUser User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actorUserId])
  @@map("audit_logs")
}

model Market {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  country     String
  province    String
  city        String
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  addresses  Address[]
  workZones  WorkZone[]

  @@map("markets")
}

model Category {
  id          String         @id @default(uuid()) @db.Uuid
  slug        String         @unique
  name        String
  group       String?        @map("category_group")
  status      CategoryStatus @default(ACTIVE)
  isInitial   Boolean        @default(false) @map("is_initial")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  contractorCategories ContractorCategory[]

  @@index([status])
  @@index([group])
  @@map("categories")
}

model Address {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  marketId   String?     @map("market_id") @db.Uuid
  label      String
  line1      String      @map("line_1")
  line2      String?     @map("line_2")
  city       String
  province   String
  postalCode String?     @map("postal_code")
  notes      String?
  type       AddressType @default(HOME) @map("address_type")
  isDefault  Boolean     @default(false) @map("is_default")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market? @relation(fields: [marketId], references: [id], onDelete: SetNull)

  contractorProfile ContractorProfile?

  @@index([userId])
  @@index([marketId])
  @@map("addresses")
}

model WorkZone {
  id          String   @id @default(uuid()) @db.Uuid
  marketId    String   @map("market_id") @db.Uuid
  slug        String
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  contractorLinks ContractorWorkZone[]

  @@unique([marketId, slug])
  @@index([marketId])
  @@map("work_zones")
}

model ContractorProfile {
  id               String                   @id @default(uuid()) @db.Uuid
  userId           String                   @unique @map("user_id") @db.Uuid
  addressId        String?                  @unique @map("address_id") @db.Uuid
  approvalStatus   ContractorApprovalStatus @default(DRAFT) @map("approval_status")
  dniNumber        String?                  @unique @map("dni_number")
  dniFrontUrl      String?                  @map("dni_front_url")
  dniBackUrl       String?                  @map("dni_back_url")
  profilePhotoUrl  String?                  @map("profile_photo_url")
  reviewNotes      String?                  @map("review_notes")
  submittedAt      DateTime?                @map("submitted_at")
  reviewedAt       DateTime?                @map("reviewed_at")
  reviewedByUserId  String?                  @map("reviewed_by_user_id") @db.Uuid
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  address    Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)
  reviewedBy User?   @relation("ContractorReviewActor", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  categories ContractorCategory[]
  workZones  ContractorWorkZone[]

  @@index([approvalStatus])
  @@index([reviewedByUserId])
  @@map("contractor_profiles")
}

model ContractorCategory {
  contractorProfileId String   @map("contractor_profile_id") @db.Uuid
  categoryId          String   @map("category_id") @db.Uuid
  isPrimary           Boolean  @default(false) @map("is_primary")
  createdAt           DateTime @default(now()) @map("created_at")

  contractorProfile ContractorProfile @relation(fields: [contractorProfileId], references: [id], onDelete: Cascade)
  category          Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@id([contractorProfileId, categoryId])
  @@index([categoryId])
  @@map("contractor_categories")
}

model ContractorWorkZone {
  contractorProfileId String   @map("contractor_profile_id") @db.Uuid
  workZoneId          String   @map("work_zone_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")

  contractorProfile ContractorProfile @relation(fields: [contractorProfileId], references: [id], onDelete: Cascade)
  workZone          WorkZone          @relation(fields: [workZoneId], references: [id], onDelete: Restrict)

  @@id([contractorProfileId, workZoneId])
  @@index([workZoneId])
  @@map("contractor_work_zones")
}
